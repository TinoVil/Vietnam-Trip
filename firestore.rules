rules_version = '2';

// Vietnam 2026 — Firestore security rules
//
// The app is hosted from a PUBLIC GitHub repo, so the Firebase config is
// world-readable. That is fine and by design: the config identifies the
// project, it does not grant access. THESE RULES are the actual lock.
//
// Data model
//   trips/vietnam2026                 <- SHARED. The plan: meta, items, days.
//                                        Edited in /builder/, read by everyone.
//   trips/vietnam2026/members/{uid}   <- PERSONAL. todos, bingo, checklist,
//                                        journal. One doc per person; you can
//                                        only ever write your own.
//
// Project: vietnamtrip26-73b1a
//
// NOTE — this file is DOCUMENTATION ONLY. The live rules are whatever is
// published in the Firebase console; nothing here is used at runtime.
//
// The real allow-list is deliberately NOT in this file: the repo is public
// (and this file is served at /firestore.rules), so putting real addresses
// here would publish them for scrapers. Keep the actual emails in the
// console copy only.
//
// To add someone: edit the allow-list in
//   console.firebase.google.com/project/_/firestore/rules

service cloud.firestore {
  match /databases/{database}/documents {

    // Emails are lower-cased before comparing: Google normalises Gmail
    // addresses, but relying on that would lock someone out over a capital
    // letter, and the failure looks like a generic permission error.
    function allowed() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email.lower() in [
             'first.traveller@example.com',   // <- real addresses live in the
             'second.traveller@example.com'   //    console copy, not in git
           ];
    }

    match /trips/{tripId} {
      // the shared plan — both of them read and write it
      allow read, write: if allowed();

      match /members/{uid} {
        // everyone on the trip can SEE each other's progress...
        allow read: if allowed();
        // ...but only ever write their own document
        allow write: if allowed() && request.auth.uid == uid;
      }
    }

    // nothing else in the project is reachable
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
